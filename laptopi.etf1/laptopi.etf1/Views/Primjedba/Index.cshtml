@model IEnumerable<laptopi.etf1.Models.Primjedba>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.sadrzaj)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.datumPrimjedbe)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.validnost)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.artikalId)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.korisnikId)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(model => item.sadrzaj)
            </td>
            <td>
                @Html.DisplayFor(model => item.datumPrimjedbe)
            </td>
            <td>
                @Html.DisplayFor(model => item.validnost)
            </td>
            <td>
                @Html.DisplayFor(model => item.artikalId)
            </td>
            <td>
                @Html.DisplayFor(model => item.korisnikId)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.primjedbaId">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.primjedbaId">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.primjedbaId">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
