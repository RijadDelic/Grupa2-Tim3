@model IEnumerable<laptopi.etf1.Models.Transakcija>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.artikalId)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.kupacId)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.prodavacId)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.tipTransakcije)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.status)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.datum)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.iznos)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.artikalId)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.kupacId)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.prodavacId)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.tipTransakcije)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.status)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.datum)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.iznos)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.transakcijaId">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.transakcijaId">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.transakcijaId">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
